# ─── Web (Vercel) ──────────────────────────────────────────────────────────────
# Leave VITE_API_URL blank for web — Vercel rewrites /api to your backend.
# Set it in Vercel dashboard under Settings > Environment Variables:
#   VITE_API_URL = https://propflow-backend.onrender.com/api

# ─── Mobile (Capacitor) ────────────────────────────────────────────────────────
# Mobile builds can't use the Vite proxy. Set this to your deployed backend:
VITE_API_URL=https://propflow-backend.onrender.com/api

# ─── Support email (shown in in-app chat widget) ───────────────────────────────
VITE_SUPPORT_EMAIL=support@blusterling.com

# ─── Stripe (Apple Pay / Google Pay) ──────────────────────────────────────────
# Only needed if STRIPE_SECRET_KEY is set on the backend.
# Get this from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
