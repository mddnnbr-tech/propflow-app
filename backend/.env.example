# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/propai"

# Auth
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Anthropic (Claude AI) — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Plaid (Banking) — https://dashboard.plaid.com
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-sandbox-secret"
PLAID_ENV="sandbox"   # sandbox | development | production

# DocuSign — https://admindemo.docusign.com/apps-and-keys
# Account ID and User ID are pre-filled from your Business Pro Trial account
DOCUSIGN_INTEGRATION_KEY="your-integration-key-from-apps-and-keys-page"
DOCUSIGN_USER_ID="f874059b-bdfa-4bca-b607-1eb40e857627"
DOCUSIGN_ACCOUNT_ID="da903ec8-efee-4f95-bd4c-2d4b0ccb63da"
DOCUSIGN_PRIVATE_KEY_PATH="./docusign_private.key"
DOCUSIGN_BASE_URL="https://na4.docusign.net/restapi"

# Email (SMTP) — use Gmail App Password or SendGrid
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="PropAI <your@gmail.com>"

# Twilio SMS — https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+15551234567"

# File Storage
# Use "local" for dev (stores in /uploads), "s3" for production
STORAGE_DRIVER="local"

# AWS S3 (only needed if STORAGE_DRIVER=s3)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="propai-uploads"

# RentCast — Market Rent Comparison (Pro tier feature)
# Free tier: 50 calls/month — https://app.rentcast.io
# Leave blank to disable market rent comparison
RENTCAST_API_KEY=""

# Subscription Tier Controls automation level
# STARTER = manual dispatch only
# GROWTH  = auto-dispatch + rich vendor emails + SMS
# PRO     = Growth + 48hr follow-ups + job completion emails + market rent
ACCOUNT_TIER="GROWTH"

# Stripe — Apple Pay / Google Pay / card processing (optional)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Internal ops email — receives managed-services interest inquiry leads
OPS_EMAIL="hello@blusterling.com"

# Support email — shown in the in-app chat widget and error messages
SUPPORT_EMAIL="support@blusterling.com"
